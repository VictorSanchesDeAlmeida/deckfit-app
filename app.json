{
  "expo": {
    "name": "DeckFit",
    "slug": "deckfit-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon/adaptive-icon.png",
    "scheme": "deckfitapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": {
        "dark": "./assets/icon/ios-dark.png",
        "light": "./assets/icon/ios-light.png",
        "tinted": "./assets/icon/ios-tinted.png"
      },
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a1228",
        "foregroundImage": "./assets/icon/adaptive-icon.png",
        "backgroundImage": "./assets/icon/adaptive-icon.png",
        "monochromeImage": "./assets/icon/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.victorsanches.deckfitapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icon/ios-light.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon/ios-light.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#07002d",
          "dark": {
            "image": "./assets/icon/ios-light.png",
            "backgroundColor": "#07002d"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
